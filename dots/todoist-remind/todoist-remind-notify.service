[Unit]
Description=Todoist reminder desktop notifications
After=graphical-session.target network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/bin/env python3 %h/.local/share/todoist-remind/remind_notify_daemon.py
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
