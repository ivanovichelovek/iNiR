// ─────────────────────────────────────────────────────────────────────────────
// 90 — Your personal overrides
// ─────────────────────────────────────────────────────────────────────────────
//
// This file is YOURS. iNiR updates will never overwrite it.
// Put any custom configuration here: extra binds, per-app window rules,
// output configuration, named workspaces, etc.
//
// Since Niri evaluates config top-to-bottom, settings here take effect
// after all other config.d files. For window-rule properties, all matching
// rules accumulate. For scalar values (like gaps), the last one wins.
//
// Examples:
//
// Named workspaces (sticky, always present)
workspace "term"
workspace "web"
workspace "chat"
workspace "code"
workspace "plans"
workspace "music"
workspace "vpn"
//
// Per-app workspace assignment

// terminal (kitty)
window-rule {
    match app-id="kitty"
    exclude title=r"^remind-"
    open-on-workspace "term"
}

// browser (zen)
window-rule {
    match app-id="zen"
    open-on-workspace "web"
    open-maximized true
}

// chat (ayugram)
window-rule {
    match app-id="com.ayugram.desktop"
    open-on-workspace "chat"
    open-maximized true
}

window-rule {
    match app-id="Alacritty"
    open-on-workspace "code"
}

// nvim runs inside a terminal — matched by window title
window-rule {
    match title=r#"(?i)nvim"#
    open-maximized true
}

// planify — opens maximized, steals focus (used for startup focus)
window-rule {
    match app-id="io.github.alainm23.planify"
    open-on-workspace "plans"
    open-maximized true
    open-focused true
}

// music (yandex)
window-rule {
    match app-id="YandexMusic"
    open-on-workspace "music"
    open-maximized true
}

// vpn (nekobox)
window-rule {
    match app-id="nekobox"
    open-on-workspace "vpn"
    open-maximized true
}

spawn-at-startup "planify"
spawn-at-startup "nekobox"

// ── Todoist reminders ────────────────────────────────────────────────────────
window-rule {
    match title=r"^remind-"
    open-floating true
}

binds {
    // ═══════════════════════════════════════════════════════════════════════
    // Tools
    // ═══════════════════════════════════════════════════════════════════════

    // Reminder list, add, delete — floating kitty windows.
    Mod+N repeat=false hotkey-overlay-title="Reminder list" { spawn "kitty" "--title" "remind-list" "--hold" "fish" "-c" "source $HOME/.local/share/todoist-remind/cli/remind_list.fish"; }
    Mod+Ctrl+N repeat=false hotkey-overlay-title="Add reminder" { spawn "kitty" "--title" "remind-add" "--hold" "fish" "-c" "source $HOME/.local/share/todoist-remind/cli/remind_add.fish"; }
    Mod+Ctrl+D repeat=false hotkey-overlay-title="Delete reminder" { spawn "kitty" "--title" "remind-del" "--hold" "fish" "-c" "source $HOME/.local/share/todoist-remind/cli/remind_del.fish"; }
}

